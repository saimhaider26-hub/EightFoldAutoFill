{
  "manifest_version": 3,
  "name": "Eightfold Autofill",
  "version": "1.0",
  "description": "Autofills the Eightfold AI job application.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_title": "Autofill Application"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.eightfold.ai/*"],
      "js": ["content.js"]
    }
  ]
}